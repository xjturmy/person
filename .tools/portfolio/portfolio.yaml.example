# preson 投资组合配置
#
# 用途:机器可读的持仓+目标权重+再平衡规则,服务于评分引擎、月度复盘、Dashboard
# 维度:维度 4 任务 4.1
# 创建:2026-05-03(step-04)
#
# ⚠️  当前为 demo 数据,_status: demo 标记。请按实际持仓修改:
#    - 填入真实 shares / cost_basis / first_buy_date
#    - 调整 target_weight 反映你的目标配置
#    - 删除未持有的公司(或保留作"观察池")
#    - 改 _status: live 表示已生效

_meta:
  version: "1.0"
  status: demo                  # demo / live
  base_currency: CNY
  last_updated: "2026-05-03"

# 全局账户层配置
account:
  total_capital: 1000000        # 总资本(元),含现金 + 持仓市值
  target_equity_ratio: 0.70     # 目标权益占比(70% 股 / 30% 现金)
  cash_min_ratio: 0.10          # 最低现金缓冲(用于加仓子弹)
  cash_max_ratio: 0.50          # 最高现金占比(超过则提示加仓)

# 再平衡触发规则(任一触发即提示)
rebalance:
  max_position_weight: 0.20     # 单一持仓上限 20%
  max_deviation_pct: 0.05       # 实际权重偏离目标 ±5pp 触发再平衡
  score_floor: 4                # F-Score < 4 触发清仓评估
  valuation_ceiling_pct: 0.85   # PE-TTM 分位 > 85% 触发减仓评估
  valuation_floor_pct: 0.15     # PE-TTM 分位 < 15% 触发加仓评估
  review_cadence_days: 30       # 月度复盘节奏

# 持仓清单
# 字段说明:
#   ticker          股票代码(对应 companies.csv 的 stock 列)
#   name            公司名(冗余,可读性)
#   status          active(在仓)/ watch(观察池,不计权重)/ exited(已平仓)
#   shares          持有股数(active 必填)
#   cost_basis      成本价(active 必填,人民币元)
#   first_buy_date  首次建仓日期 YYYY-MM-DD
#   target_weight   目标权重(0-1,active 必填)
#   max_weight      硬上限(防止过度集中)
#   thesis          投资逻辑(一句话)
#   tags            分类标签(行业/风格)

holdings:

  - ticker: "600519"
    name: 贵州茅台
    status: watch
    target_weight: 0.10
    max_weight: 0.15
    thesis: "白酒龙头 + 高 ROE + 强护城河;PE 9% 分位低估"
    tags: [消费, 白酒, 价值]

  - ticker: "000858"
    name: 五粮液
    status: watch
    target_weight: 0.05
    max_weight: 0.10
    thesis: "次高端白酒;F-Score 2023 拿到 9/9 满分,2025 PE 异常待跟踪"
    tags: [消费, 白酒, 价值]

  - ticker: "300750"
