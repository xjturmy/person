<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.preson.monthly</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-lc</string>
        <string>cd /Users/gongyong/Desktop/Keyi/preson &amp;&amp; .venv/bin/python .tools/portfolio/monthly_review.py &amp;&amp; .venv/bin/python .tools/portfolio/render_monthly_pdf.py &amp;&amp; .venv/bin/python .tools/portfolio/send_monthly_email.py</string>
